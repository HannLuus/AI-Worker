# Frontend (Vite) — copy to frontend/.env.local (see frontend/.gitignore *.local)
# Self-hosted only: copy ANON_KEY JWT from VPS /opt/supabase/.env
# Browser note: if the app is served on HTTPS (e.g. Vercel), the API URL must be HTTPS too or the browser blocks mixed content.
VITE_SUPABASE_URL=http://72.61.208.230:8000
VITE_SUPABASE_ANON_KEY=your_anon_jwt_from_vps

# Root .env (CLI, MCP): use JWT anon/service_role from the VPS Supabase secrets file — never an SSH key.
# On the server: values often live in /opt/supabase/.env or your compose env (SERVICE_ROLE_KEY, ANON_KEY).
SUPABASE_URL=http://YOUR_VPS_IP:8000
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Direct Postgres (MCP SQL tools + ./scripts/supabase-db.sh). From VPS: DB password in compose / Studio.
# Example: postgresql://postgres:YOUR_DB_PASSWORD@72.61.208.230:5432/postgres
SUPABASE_DB_URL=
VITE_OPENROUTER_API_KEY=your_openrouter_api_key_here

# Supabase Edge Function Secrets
# Set via: Supabase Dashboard > Project Settings > Edge Functions > Secrets
# or CLI: supabase secrets set OPENROUTER_API_KEY=xxx
OPENROUTER_API_KEY=your_openrouter_api_key_here
RESEND_API_KEY=your_resend_api_key_here
CRON_SECRET=aicoworker-cron-secret-2026

# Stripe (Phase 5)
STRIPE_SECRET_KEY=your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here
VITE_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key_here
